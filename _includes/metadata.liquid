{% assign has_google_verification = false %}
{% if site.google_site_verification != blank %}
  {% assign has_google_verification = true %}
{% endif %}
{% assign has_bing_verification = false %}
{% if site.bing_site_verification != blank %}
  {% assign has_bing_verification = true %}
{% endif %}
{% if has_google_verification or has_bing_verification %}
  <!-- Website verification -->
  {% if has_google_verification %}
    <meta name="google-site-verification" content="{{ site.google_site_verification }}">
  {% endif %}
  {% if has_bing_verification %}
    <meta name="msvalidate.01" content="{{ site.bing_site_verification }}">
  {% endif %}
  <meta http-equiv="Permissions-Policy" content="interest-cohort=()">
{% endif %}

{% capture author_name %}{{ site.first_name }}{% if site.middle_name %} {{ site.middle_name }}{% endif %} {{ site.last_name }}{% endcapture %}
{% assign author_name = author_name | strip %}

{% if site.title == 'blank' %}
  {% assign site_title = author_name %}
{% else %}
  {% assign site_title = site.title %}
{% endif %}

{% assign is_home_page = false %}
{% if page.url == '/' or page.url == '/index.html' %}
  {% assign is_home_page = true %}
{% endif %}
{% assign is_blog_post = false %}
{% if page.url contains '/blog/' %}
  {% unless page.url contains '/tag/' or page.url contains '/category/' or page.url == '/blog/' or page.url == '/blog/index.html' %}
    {% assign is_blog_post = true %}
  {% endunless %}
{% endif %}

{% assign page_description = page.description | default: site.description | strip_html | normalize_whitespace %}
{% assign site_description = site.description | strip_html | normalize_whitespace %}
{% if site.canonical_url_root %}
  {% assign canonical_url = page.url | replace: 'index.html', '' | prepend: site.canonical_url_root %}
  {% assign site_root_url = site.canonical_url_root | append: '/' %}
{% else %}
  {% assign canonical_url = page.url | replace: 'index.html', '' | absolute_url %}
  {% assign site_root_url = '/' | absolute_url %}
{% endif %}
{% assign website_id = site_root_url | append: '#website' %}
{% assign person_id = site_root_url | append: '#person' %}
{% assign page_id = canonical_url | append: '#webpage' %}

{% if is_home_page %}
  {% assign page_name = site_title %}
{% elsif page.title == null or page.title == '' or page.title == 'blank' %}
  {% assign page_name = site_title %}
{% else %}
  {% assign page_name = page.title %}
{% endif %}

{% if is_home_page %}
  {% if page.subtitle %}
    {% capture document_title %}{{ site_title }} | {{ page.subtitle }}{% endcapture %}
  {% else %}
    {% assign document_title = site_title %}
  {% endif %}
{% elsif page.url == '/blog/index.html' %}
  {% capture document_title %}{{ page.title }} | {{ site_title }}{% endcapture %}
{% elsif page.title == null or page.title == '' %}
  {% capture document_title %}{{ page.date | date: '%Y' }} | {{ site_title }}{% endcapture %}
{% else %}
  {% capture document_title %}{{ page.title }} | {{ site_title }}{% endcapture %}
{% endif %}
{% assign document_title = document_title | strip %}

{% assign sameaslinks = '' | split: ',' %}
{% for social in site.data.socials %}
  {% assign social_key = social[0] %}
  {% assign social_value = social[1] %}
  {% if social_value != blank %}
    {% case social_key %}
      {% when 'acm_id' %}
        {% capture link %}https://dl.acm.org/profile/{{ social_value }}/{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'arxiv_id' %}
        {% capture link %}https://arxiv.org/a/{{ social_value }}.html{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'bluesky_url' %}
        {% assign sameaslinks = sameaslinks | push: social_value %}
      {% when 'dblp_url' %}
        {% assign sameaslinks = sameaslinks | push: social_value %}
      {% when 'facebook_id' %}
        {% capture link %}https://facebook.com/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'flickr_id' %}
        {% capture link %}https://www.flickr.com/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'github_username' %}
        {% capture link %}https://github.com/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'gitlab_username' %}
        {% capture link %}https://gitlab.com/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'hal_id' %}
        {% capture link %}https://cv.hal.science/{{ social_value }}/{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'ieee_id' %}
        {% capture link %}https://ieeexplore.ieee.org/author/{{ social_value }}/{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'inspirehep_id' %}
        {% capture link %}https://inspirehep.net/authors/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'instagram_id' %}
        {% capture link %}https://instagram.com/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'kaggle_id' %}
        {% capture link %}https://www.kaggle.com/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'keybase_username' %}
        {% capture link %}https://keybase.io/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'lastfm_id' %}
        {% capture link %}https://www.last.fm/user/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'lattes_id' %}
        {% capture link %}http://lattes.cnpq.br/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'leetcode_id' %}
        {% capture link %}https://leetcode.com/u/{{ social_value }}/{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'linkedin_username' %}
        {% capture link %}https://www.linkedin.com/in/{{ social_value }}/{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'mastodon_username' %}
        {% capture link %}https://{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'medium_username' %}
        {% capture link %}https://medium.com/@{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'orcid_id' %}
        {% capture link %}https://orcid.org/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'osf_id' %}
        {% capture link %}https://osf.io/{{ social_value }}/{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'pinterest_id' %}
        {% capture link %}https://www.pinterest.com/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'publons_id' %}
        {% capture link %}https://publons.com/a/{{ social_value }}/{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'quora_username' %}
        {% capture link %}https://www.quora.com/profile/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'research_gate_profile' %}
        {% capture link %}https://www.researchgate.net/profile/{{ social_value }}/{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'scholar_userid' %}
        {% capture link %}https://scholar.google.com/citations?user={{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'scopus_id' %}
        {% capture link %}https://www.scopus.com/authid/detail.uri?authorId={{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'semanticscholar_id' %}
        {% capture link %}https://www.semanticscholar.org/author/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'spotify_id' %}
        {% capture link %}https://open.spotify.com/user/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'stackoverflow_id' %}
        {% capture link %}https://stackoverflow.com/users/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'strava_userid' %}
        {% capture link %}https://www.strava.com/athletes/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'telegram_username' %}
        {% capture link %}https://telegram.me/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'unsplash_id' %}
        {% capture link %}https://unsplash.com/@{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'whatsapp_number' %}
        {% capture link %}https://wa.me/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'wikidata_id' %}
        {% capture link %}https://www.wikidata.org/wiki/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'wikipedia_id' %}
        {% capture link %}https://wikipedia.org/wiki/User:{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'work_url' %}
        {% assign sameaslinks = sameaslinks | push: social_value %}
      {% when 'x_username' %}
        {% capture link %}https://twitter.com/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'youtube_id' %}
        {% capture link %}https://youtube.com/@{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% when 'zotero_username' %}
        {% capture link %}https://www.zotero.org/{{ social_value }}{% endcapture %}
        {% assign sameaslinks = sameaslinks | push: link %}
      {% else %}
        {% if social_value.url %}
          {% assign sameaslinks = sameaslinks | push: social_value.url %}
        {% endif %}
    {% endcase %}
  {% endif %}
{% endfor %}
{% if site.person and site.person.same_as %}
  {% assign sameaslinks = sameaslinks | concat: site.person.same_as %}
{% endif %}
{% assign sameaslinks = sameaslinks | compact | uniq %}

<!-- Standard metadata -->
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title>{{ document_title }}</title>
<meta name="author" content="{{ author_name }}">
<meta name="description" content="{{ page_description }}">
{% if page.keywords or site.keywords %}
  <meta name="keywords" content="{% if page.keywords %}{{ page.keywords }}{% else %}{{ site.keywords }}{% endif %}">
{% endif %}

{% if site.serve_og_meta %}
  <!-- OpenGraph -->
  <meta property="og:site_name" content="{{ site_title }}">
  <meta property="og:type" content="{% if is_blog_post %}article{% else %}website{% endif %}">
  <meta property="og:title" content="{{ document_title }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:description" content="{{ page_description }}">
  {% if page.og_image or site.og_image %}
    <meta property="og:image" content="{% if page.og_image %}{{ page.og_image }}{% else %}{{ site.og_image }}{% endif %}">
  {% endif %}
  <meta property="og:locale" content="{{ site.lang }}">

  <!-- Twitter card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ document_title }}">
  <meta name="twitter:description" content="{{ page_description }}">
  {% if page.og_image or site.og_image %}
    <meta name="twitter:image" content="{% if page.og_image %}{{ page.og_image }}{% else %}{{ site.og_image }}{% endif %}">
  {% endif %}
  {% if site.x_username %}
    <meta name="twitter:site" content="@{{ site.x_username }}">
    <meta name="twitter:creator" content="@{{ site.x_username }}">
  {% endif %}
{% endif %}

{% if site.serve_schema_org %}
  <!-- Schema.org -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": {{ website_id | jsonify }},
          "url": {{ site_root_url | jsonify }},
          "name": {{ site_title | jsonify }},
          "description": {{ site_description | jsonify }},
          "inLanguage": {{ site.lang | jsonify }}
        },
        {
          "@type": "Person",
          "@id": {{ person_id | jsonify }},
          "name": {{ author_name | jsonify }},
          "url": {{ site_root_url | jsonify }}{% if site.data.socials.email != blank %},
          "email": {{ 'mailto:' | append: site.data.socials.email | jsonify }}{% endif %}{% if site.person.job_title != blank %},
          "jobTitle": {{ site.person.job_title | jsonify }}{% endif %}{% if site.person.affiliation != blank %},
          "affiliation": {
            "@type": "Organization",
            "name": {{ site.person.affiliation | jsonify }}
          }{% endif %}{% if sameaslinks != blank %},
          "sameAs": {{ sameaslinks | jsonify }}{% endif %}
        },
        {% if is_home_page %}
        {
          "@type": "ProfilePage",
          "@id": {{ page_id | jsonify }},
          "url": {{ canonical_url | jsonify }},
          "name": {{ site_title | jsonify }},
          "description": {{ page_description | jsonify }},
          "inLanguage": {{ site.lang | jsonify }},
          "isPartOf": {
            "@id": {{ website_id | jsonify }}
          },
          "mainEntity": {
            "@id": {{ person_id | jsonify }}
          },
          "about": {
            "@id": {{ person_id | jsonify }}
          }
        }
        {% else %}
        {
          "@type": "{% if is_blog_post %}BlogPosting{% else %}WebPage{% endif %}",
          "@id": {{ page_id | jsonify }},
          "url": {{ canonical_url | jsonify }},
          "name": {{ page_name | jsonify }},
          "description": {{ page_description | jsonify }},
          "inLanguage": {{ site.lang | jsonify }},
          "isPartOf": {
            "@id": {{ website_id | jsonify }}
          },
          "author": {
            "@id": {{ person_id | jsonify }}
          }{% if is_blog_post %},
          "headline": {{ page_name | jsonify }},
          "mainEntityOfPage": {{ canonical_url | jsonify }},
          "datePublished": {{ page.date | date_to_xmlschema | jsonify }},
          "dateModified": {{ page.last_modified_at | default: page.date | date_to_xmlschema | jsonify }}{% endif %}
        }
        {% endif %}
      ]
    }
  </script>
{% endif %}
